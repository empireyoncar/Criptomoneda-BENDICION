    }
    # ============================================================
    # FRONTEND STAKING (HTML) – puerto 5007
    # Ruta: /CriptoBendicion/staking/
    # ============================================================
    location /CriptoBendicion/staking/ {
        proxy_pass http://127.0.0.1:5007/staking/;
        proxy_set_header Host $host;
