    }
    # ============================================================
    # FRONTEND P2P (HTML) – puerto 5013
    # Ruta: /CriptoBendicion/p2p/
    # ============================================================
    location /CriptoBendicion/p2p/ {
        proxy_pass http://127.0.0.1:5013/p2p/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ============================================================
    # BACKEND P2P (API) – puerto 5012
    # Ruta: /CriptoBendicion/p2p_api/
    # ============================================================
    location /CriptoBendicion/p2p_api/ {
        proxy_pass http://127.0.0.1:5012/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ============================================================
    # CHAT P2P (WebSocket) – puerto 5014
    # Ruta: /CriptoBendicion/p2p_chat/
    # ============================================================
    location /CriptoBendicion/p2p_chat/ {
        proxy_pass http://127.0.0.1:5014/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600;
    }

    # ============================================================
    # FRONTEND KYC (HTML) – puerto 5016
    # Ruta: /CriptoBendicion/kyc/
    # ============================================================
    location /CriptoBendicion/kyc/ {
        proxy_pass http://127.0.0.1:5016/kyc/;
        proxy_set_header Host $host;
