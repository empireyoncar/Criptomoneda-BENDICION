    }
    # ============================================================
    # BACKEND DON (API) – puerto 5008
    # ============================================================
    location /CriptoBendicion/don_api/ {
        proxy_pass http://127.0.0.1:5008/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
